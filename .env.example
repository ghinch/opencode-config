# ═══════════════════════════════════════════════════════════════════
# OpenCode + Agent Vault — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# Copy to .env and fill in values:  cp .env.example .env
#
# Runtime: Apple Container (apple/container)
# Startup:  scripts/start.sh (uses `container run` directly)
#
# Quick start:
#   container system start
#   container network create internal          # one-time
#   container build -f Dockerfile.opencode -t opencode-sandbox:latest .
#   container build -f Dockerfile.bootstrap -t agent-vault-bootstrap:latest .
#   source .env
#   ./scripts/start.sh agent-vault             # start credential proxy
#   <run bootstrap to push credentials — see below>
#   ./scripts/start.sh                         # start remaining services
#   opencode attach http://localhost:4096 --password <OPENCODE_SERVER_PASSWORD>
#
# Stop:  ./scripts/stop.sh
#
# NOTE: container-compose was found to be buggy (env_file not loaded,
# name mismatch, silent container failures). scripts/start.sh uses
# `container run` directly for reliability.
#
# ═══════════════════════════════════════════════════════════════════

# -- Agent Vault Server --
# Master password for encrypting the agent-vault database.
# Generate: openssl rand -base64 32
AGENT_VAULT_MASTER_PASSWORD=

# -- Admin account (used by bootstrap + token-refresher) --
AGENT_VAULT_EMAIL=
AGENT_VAULT_PASSWORD=

# The vault within agent-vault.
AGENT_VAULT_VAULT=default

# -- OpenCode Server --
# Password for the opencode HTTP API (basic auth).
# Set this, then pass it when attaching:
#   opencode attach http://localhost:4096 --password <this-value>
OPENCODE_SERVER_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# Bootstrap: one-shot credential push (manual)
# ═══════════════════════════════════════════════════════════════════
#
# After starting agent-vault, push your opencode credentials:
#
#   source .env
#   mkdir -p ~/.config/opencode/agent-token
#
#   container run --rm \
#     --volume ~/.local/share/opencode/auth.json:/tmp/auth.json:ro \
#     --volume ~/.config/opencode/agent-token:/token \
#     --network internal \
#     -e AGENT_VAULT_ADDR=http://agent-vault:14321 \
#     -e AGENT_VAULT_EMAIL=$AGENT_VAULT_EMAIL \
#     -e AGENT_VAULT_PASSWORD=$AGENT_VAULT_PASSWORD \
#     agent-vault-bootstrap:latest
#
# Then start remaining services:
#   ./scripts/start.sh
