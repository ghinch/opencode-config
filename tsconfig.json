{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "bun"]
  },
  "include": [
    "skills/**/*.ts",
    "plugins/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "plugins/**/*.test.ts"
  ]
}
